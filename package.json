{
  "name": "riva-backend",
  "version": "1.0.0",
  "description": "Riva Data Backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run start:all",
    "start:dev": "npm run start:all",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --testPathPatterns=unit",
    "test:integration": "jest --testPathPatterns=integration",
    "test:all": "npm run test:unit && npm run test:integration",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "clear:redis": "ts-node -r dotenv/config scripts/clear-redis.ts",
    "clear:r2": "ts-node -r dotenv/config scripts/clear-r2.ts",
    "clear:all": "ts-node -r dotenv/config scripts/clear-all-storage.ts",
    "worker:status": "ts-node -r dotenv/config scripts/check-worker-status.ts",
    "worker:start": "ts-node -r dotenv/config src/workers.ts",
    "worker:dev": "nodemon --watch src --ext ts --exec ts-node -r dotenv/config src/workers.ts",
    "test:video-upload": "ts-node -r dotenv/config scripts/test-video-upload.ts",
    "start:gateway": "ts-node -r dotenv/config src/gateway/main.ts",
    "start:user-register": "ts-node -r dotenv/config src/user/ports/register/register-service.ts",
    "start:user-login": "ts-node -r dotenv/config src/user/ports/login/login-service.ts",
    "start:user-details": "ts-node -r dotenv/config src/user/ports/user_details/details-service.ts",
    "start:user-refresh": "ts-node -r dotenv/config src/user/ports/refresh_token/refresh-service.ts",
    "start:course-create": "ts-node -r dotenv/config src/course/ports/create-course/create-course-service.ts",
    "start:course-read": "ts-node -r dotenv/config src/course/ports/read-course/read-course-service.ts",
    "start:course-update": "ts-node -r dotenv/config src/course/ports/update-course/update-course-service.ts",
    "start:course-delete": "ts-node -r dotenv/config src/course/ports/delete-course/delete-course-service.ts",
    "start:course-list": "ts-node -r dotenv/config src/course/ports/list-courses/list-courses-service.ts",
    "start:course-published": "ts-node -r dotenv/config src/course/ports/get-published-courses/get-published-courses-service.ts",
    "start:course-add-module": "ts-node -r dotenv/config src/course/ports/add-module/add-module-service.ts",
    "start:course-update-module": "ts-node -r dotenv/config src/course/ports/update-module/update-module-service.ts",
    "start:course-delete-module": "ts-node -r dotenv/config src/course/ports/delete-module/delete-module-service.ts",
    "start:course-get-lesson": "ts-node -r dotenv/config src/course/ports/get-lesson/get-lesson-service.ts",
    "start:upload-initiate": "ts-node -r dotenv/config src/upload/ports/initiate-upload/initiate-upload-service.ts",
    "start:upload-chunk": "ts-node -r dotenv/config src/upload/ports/upload-chunk/upload-chunk-service.ts",
    "start:upload-thumbnail": "ts-node -r dotenv/config src/upload/ports/upload-thumbnail/upload-thumbnail-service.ts",
    "start:upload-youtube": "ts-node -r dotenv/config src/upload/ports/youtube-video/youtube-video-service.ts",
    "start:upload-update-lesson": "ts-node -r dotenv/config src/upload/ports/update-lesson-qualities/update-lesson-qualities-service.ts",
    "start:upload-direct-video": "ts-node -r dotenv/config src/upload/ports/direct-video/direct-video-service.ts",
    "start:upload-direct-thumbnail": "ts-node -r dotenv/config src/upload/ports/direct-thumbnail/direct-thumbnail-service.ts",
    "start:video-upload-460p": "ts-node -r dotenv/config src/video/ports/video-upload-460p/video-upload-460p-service.ts",
    "start:video-upload-720p": "ts-node -r dotenv/config src/video/ports/video-upload-720p/video-upload-720p-service.ts",
    "start:video-upload-1080p": "ts-node -r dotenv/config src/video/ports/video-upload-1080p/video-upload-1080p-service.ts",
    "start:video-process": "ts-node -r dotenv/config src/video/ports/video-process/video-process-service.ts",
    "start:contact-create": "ts-node -r dotenv/config src/contact/ports/create-contact/create-contact-service.ts",
    "start:all-user-services": "concurrently \"npm run start:user-register\" \"npm run start:user-login\" \"npm run start:user-details\" \"npm run start:user-refresh\"",
    "start:all-course-services": "concurrently \"npm run start:course-create\" \"npm run start:course-read\" \"npm run start:course-update\" \"npm run start:course-delete\" \"npm run start:course-list\" \"npm run start:course-published\" \"npm run start:course-add-module\" \"npm run start:course-update-module\" \"npm run start:course-delete-module\" \"npm run start:course-get-lesson\"",
    "start:all-upload-services": "concurrently \"npm run start:upload-initiate\" \"npm run start:upload-chunk\" \"npm run start:upload-thumbnail\" \"npm run start:upload-youtube\" \"npm run start:upload-update-lesson\" \"npm run start:upload-direct-video\" \"npm run start:upload-direct-thumbnail\"",
    "start:all-video-services": "concurrently \"npm run start:video-upload-460p\" \"npm run start:video-upload-720p\" \"npm run start:video-upload-1080p\"",
    "start:all-contact-services": "concurrently \"npm run start:contact-create\"",
    "start:all-services": "concurrently \"npm run start:all-user-services\" \"npm run start:all-course-services\" \"npm run start:all-upload-services\" \"npm run start:all-video-services\" \"npm run start:all-contact-services\"",
    "start:workers": "ts-node -r dotenv/config src/workers.ts",
    "start:all": "concurrently \"npm run start:gateway\" \"npm run start:all-services\" \"npm run start:workers\"",
    "show:ports": "bash show-all-ports.sh",
    "start:with-ports": "npm run show:ports && npm run start:all"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/lib-storage": "^3.1014.0",
    "@aws-sdk/node-http-handler": "^3.370.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@prisma/client": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.73.5",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^2.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^16.0.3",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.3.2",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma": "^5.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "stripe": "^21.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.2",
    "@types/cache-manager-redis-store": "^2.0.4",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.8",
    "@types/passport-local": "^1.0.35",
    "@types/supertest": "^7.2.0",
    "concurrently": "^8.2.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "nestjs",
    "api",
    "mongodb",
    "prisma",
    "courses",
    "education"
  ],
  "author": "Riva Data Team",
  "license": "MIT"
}
